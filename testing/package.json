{
  "name": "@zoijs/testing",
  "version": "0.1.0",
  "description": "Tiny first-party testing helpers for Zoijs: render, queries, fireEvent, waitFor — drive the real DOM. No custom renderer, no build step.",
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "author": "Zoijs contributors (https://zoijs.dev)",
  "license": "MIT",
  "homepage": "https://zoijs.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zoijs/zoijs.git",
    "directory": "testing"
  },
  "bugs": {
    "url": "https://github.com/Zoijs/zoijs/issues"
  },
  "keywords": [
    "zoijs",
    "testing",
    "test",
    "dom",
    "render",
    "fireEvent",
    "waitFor",
    "no-build",
    "no-jsx"
  ],
  "peerDependencies": {
    "@zoijs/core": "^1.0.0"
  },
  "scripts": {
    "test": "node --test --import ./tests/setup-dom.js",
    "test:types": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@zoijs/core": "file:../framework",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3"
  }
}
